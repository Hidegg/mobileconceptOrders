const LAPTOP_DATA = {
  "Laptop (general)": {"Instalare Sistem de Operare":150,"Instalare SSD":100,"Curatare Praf + Pasta Termo":200,"Instalare Programe":80,"Upgrade SSD 128GB":390,"Upgrade SSD 256GB":490,"Upgrade SSD 512GB":650,"Upgrade SSD 1TB":1150,"Upgrade SSD 2TB":1450,"Manopera Inlocuire Piese":100}
};

const BRANDS = [
  { id: "iphone",  name: "iPhone",  data: IPHONE_DATA },
  { id: "samsung", name: "Samsung", data: SAMSUNG_DATA },
  { id: "huawei",  name: "Huawei",  data: HUAWEI_DATA },
  { id: "laptop",  name: "Laptop",  data: LAPTOP_DATA }
];

const BRAND_LOGOS = {
  iphone:  "https://cdn.simpleicons.org/apple",
  samsung: "https://cdn.simpleicons.org/samsung",
  huawei:  "https://cdn.simpleicons.org/huawei",
  laptop:  null
};

function getPhoneImageUrl(brandId, modelName) {
  let name = modelName;
  let prefix;
  if (brandId === "iphone") { prefix = "apple"; }
  else if (brandId === "samsung") { prefix = "samsung"; name = name.replace(/^Samsung\s+/i,""); if (!/^galaxy\s/i.test(name)) name = "Galaxy " + name; }
  else if (brandId === "huawei") { prefix = "huawei"; name = name.replace(/^Huawei\s+/i,""); }
  else { prefix = brandId; }
  const slug = name.toLowerCase().replace(/[()\/+]/g,"").replace(/\s+/g,"-").replace(/-+/g,"-").replace(/^-|-$/g,"");
  return `https://fdn2.gsmarena.com/vv/bigpic/${prefix}-${slug}.jpg`;
}

const PHONE_FALLBACK = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%238176FF' stroke-width='1.5'%3E%3Crect x='5' y='1' width='14' height='22' rx='3' ry='3'/%3E%3Ccircle cx='12' cy='18.5' r='.8' fill='%238176FF' stroke='none'/%3E%3C/svg%3E";

function onPhoneImgError(el) {
  el.onerror = null;
  el.src = PHONE_FALLBACK;
}

let state = { brand: null, series: null, model: null, cart: [], date: null, timeSlot: null, name: "", phone: "", orderId: null, mode: null, view: 'brand', description: "" };
let currentStep = 0;
let navDir = 1;

const EASE_OUT = 'cubic-bezier(0.22,1,0.36,1)';
const ANIM_MS  = 300;

function _absorbClicks(ms) {
  const shield = document.createElement('div');
  shield.style.cssText = 'position:fixed;inset:0;z-index:99999;';
  document.body.appendChild(shield);
  setTimeout(() => shield.remove(), ms || 600);
}

function animateIn(el) {
  const x = navDir * 26;
  navDir = 1;
  el.style.willChange = 'transform, opacity';
  el.style.transition = 'none';
  el.style.opacity    = '0';
  el.style.transform  = `translateX(${x}px)`;
  el.getBoundingClientRect(); // force style flush so initial state is committed
  el.style.transition = `opacity ${ANIM_MS}ms ${EASE_OUT}, transform ${ANIM_MS}ms ${EASE_OUT}`;
  el.style.opacity    = '1';
  el.style.transform  = 'translateX(0)';
  el.addEventListener('transitionend', () => {
    el.style.willChange = '';
    el.style.opacity = el.style.transform = el.style.transition = '';
  }, { once: true });
}


function setModalSize(cls) {
  const modal = document.getElementById('booking-modal');
  modal.classList.remove('modal-wide');
  if (cls) modal.classList.add(cls);
}

function setScrollable(enable) {
  document.getElementById('booking-scroll').classList.toggle('scroll-locked', !enable);
}

document.addEventListener("DOMContentLoaded", () => {
  showBrands(); openBooking();

  // Prevent background scroll when touching outside the scrollable area or when locked.
  // IMPORTANT: never prevent on the modal header — that kills the back/close buttons.
  document.getElementById('booking-overlay').addEventListener('touchmove', function(e) {
    const scroll = document.getElementById('booking-scroll');
    const header = document.querySelector('.modal-header');
    if (header && header.contains(e.target)) return; // always let header touches through
    const inScroll = scroll.contains(e.target);
    const isLocked = scroll.classList.contains('scroll-locked');
    if (!inScroll || isLocked) e.preventDefault();
  }, { passive: false });

  // Touch tap visual feedback — mirrors desktop hover, driven by touchstart/touchmove/touchend
  // so it works reliably on iOS (CSS :active alone is unreliable on divs).
  (function() {
    const SELECTOR = '.brand-card:not(.placeholder),.model-card,.time-slot,.choice-card';
    let activeCard = null;
    function clearActive() {
      if (activeCard) { activeCard.classList.remove('touch-active'); activeCard = null; }
    }
    const scroll = document.getElementById('booking-scroll');
    scroll.addEventListener('touchstart', function(e) {
      clearActive();
      const card = e.target.closest ? e.target.closest(SELECTOR) : null;
      if (!card) return;
      activeCard = card;
      card.classList.add('touch-active');
    }, { passive: true });
    // If finger moves, it's a scroll — remove highlight immediately
    scroll.addEventListener('touchmove', clearActive, { passive: true });
    // On lift, keep highlight briefly so user sees it, then clear
    scroll.addEventListener('touchend', function() {
      if (activeCard) setTimeout(clearActive, 180);
    }, { passive: true });
    scroll.addEventListener('touchcancel', clearActive, { passive: true });
  })();

  // ── Ghost-click fix for navigating cards ──────────────────────────────────
  // On iOS, touchstart→touchend synthesizes a click ~300ms later at the original
  // coordinates. If the view has changed by then, the click lands on the new card.
  // Calling preventDefault() on touchstart kills the entire synthesized chain.
  // We then fire the action ourselves on touchend.
  (function() {
    const NAV_SELECTOR = '.choice-card, .brand-card:not(.placeholder), .model-card, .svc-card';
    let _tapTarget = null, _tapMoved = false;

    document.getElementById('booking-overlay').addEventListener('touchstart', function(e) {
      const card = e.target.closest(NAV_SELECTOR);
      if (!card) { _tapTarget = null; return; }
      e.preventDefault();          // kills synthesized click — no ghost taps
      _tapTarget = card;
      _tapMoved  = false;
    }, { passive: false });

    document.getElementById('booking-overlay').addEventListener('touchmove', function() {
      if (_tapTarget) _tapMoved = true;
    }, { passive: true });

    document.getElementById('booking-overlay').addEventListener('touchend', function() {
      if (!_tapTarget || _tapMoved) { _tapTarget = null; return; }
      const card = _tapTarget;
      _tapTarget = null;

      if (card.classList.contains('svc-card')) {
        toggleService(card);

      } else if (card.classList.contains('choice-card')) {
        const mode = card.classList.contains('choice-card-servicii') ? 'servicii'
                   : card.classList.contains('choice-card-diagnoza')  ? 'diagnoza' : null;
        if (mode) selectMode(mode, card);

      } else if (card.classList.contains('brand-card')) {
        const m = (card.getAttribute('onclick') || '').match(/selectBrand\('([^']+)'/);
        if (m) selectBrand(m[1], card);

      } else if (card.classList.contains('model-card')) {
        const m = (card.getAttribute('onclick') || '').match(/selectModel\('([^']+)'/);
        if (m) selectModel(m[1], card);
      }
    }, { passive: true });
  })();
});

function showBrands() {
  state.brand = null; state.series = null; state.model = null; state.cart = [];
  state.view = 'brand';
  updateCartUI();
  document.getElementById("modal-title").textContent = "Alege Marca Telefonului";
  document.getElementById("brand-view").style.display = "block";
  document.getElementById("series-view").style.display = "none";
  document.getElementById("model-view").style.display = "none";
  document.getElementById("choice-view").style.display = "none";
  document.getElementById("service-view").style.display = "none";
  document.getElementById("btn-next-0").style.display = "none";
  document.getElementById("description-view").style.display = "none";
  document.getElementById("booking-container").classList.remove("wide-container");
  setModalSize(''); setDot(0); updateBackBtn();
  setScrollable(false);
  const container = document.getElementById("brand-view");
  container.innerHTML = `<div class="brand-grid">` + BRANDS.map(b => {
    const logoUrl = BRAND_LOGOS[b.id];
    const iconHtml = logoUrl
      ? `<img class="brand-logo" src="${logoUrl}" alt="${b.name}" onerror="this.style.opacity='.25'">`
      : `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="8 21 12 17 16 21"/></svg>`;
    const count = b.placeholder ? 'In curand' : (Object.keys(b.data).length === 1 ? 'Service & reparatii' : Object.keys(b.data).length + ' modele');
    const click = b.placeholder ? '' : `onclick="selectBrand('${b.id}', this)"`;
    return `<div class="brand-card${b.placeholder ? ' placeholder' : ''}" ${click}><div class="brand-icon">${iconHtml}</div><div class="brand-name">${b.name}</div><div class="brand-count">${count}</div></div>`;
  }).join("") + `</div>`;
  animateIn(container);
}

function selectBrand(brandId, el) {
  const brand = BRANDS.find(b => b.id === brandId);
  if (!brand) return;
  function proceed() {
    state.brand = brand; state.series = null; state.model = null; state.cart = [];
    updateCartUI();
    const models = Object.keys(brand.data);
    if (models.length === 1) { selectModel(models[0]); return; }
    if (brandId === 'samsung') { showSeriesView(); return; }
    showModelGrid(models);
  }
  if (el) {
    el.classList.add('tapping');
    setTimeout(proceed, 230);
  } else {
    proceed();
  }
}

function selectModel(modelName, el) {
  if (!state.brand.data[modelName]) return;
  function proceed() {
    state.model = modelName; state.cart = []; state.mode = null;
    showChoiceView();
  }
  if (el) { el.classList.add('tapping'); setTimeout(proceed, 230); }
  else { proceed(); }
}

function getServicePriceRange() {
  const services = state.brand.data[state.model];
  if (!services) return { min: 0, max: 0 };
  const prices = Object.values(services).filter(p => p > 0);
  return { min: Math.min(...prices), max: Math.max(...prices) };
}

function showChoiceView() {
  document.getElementById("modal-title").textContent = "Ce doresti?";
  document.getElementById("brand-view").style.display = "none";
  document.getElementById("series-view").style.display = "none";
  document.getElementById("model-view").style.display = "none";
  document.getElementById("choice-view").style.display = "block";
  document.getElementById("service-view").style.display = "none";
  document.getElementById("description-view").style.display = "none";
  document.getElementById("btn-next-0").style.display = "none";
  document.getElementById("booking-container").classList.remove("wide-container");
  setModalSize(''); state.view = 'choice'; setDot(2); updateBackBtn();
  setScrollable(false);

  document.getElementById("choice-view").innerHTML = `
  <div class="choice-grid">
    <div class="choice-card choice-card-servicii" onclick="selectMode('servicii', this)">
      <div class="choice-icon-wrap">🔧</div>
      <div class="choice-body">
        <div class="choice-title">Servicii &amp; Reparatii</div>
        <div class="choice-sub">Alege serviciile de reparatie necesare</div>

        <div class="choice-tags"><span class="choice-tag">Pret fix</span><span class="choice-tag">Garantie inclusa</span></div>
      </div>
      <div class="choice-right"><span class="choice-arrow">›</span></div>
    </div>
    <div class="choice-card choice-card-diagnoza" onclick="selectMode('diagnoza', this)">
      <div class="choice-icon-wrap green">🔍</div>
      <div class="choice-body">
        <div class="choice-title">Diagnoza</div>
        <div class="choice-sub">Verificare completa a dispozitivului</div>
        <div class="choice-price-zero">0 RON</div>
        <div class="choice-tags"><span class="choice-tag">Fara obligatii</span><span class="choice-tag">Pe loc</span></div>
      </div>
      <div class="choice-right"><span class="choice-arrow">›</span></div>
    </div>
  </div>`;
  animateIn(document.getElementById("choice-view"));
}

function selectMode(mode, el) {
  function proceed() {
    const prevMode = state.mode;
    state.mode = mode;
    if (mode === 'servicii') { state.cart = []; showServiceView(); }
    else if (mode === 'diagnoza') { state.cart = ['Diagnosticare in Locatie']; showDescriptionView(); }
  }
  if (el) { el.classList.add('tapping'); setTimeout(proceed, 230); }
  else { proceed(); }
}

function showDescriptionView() {
  document.getElementById("modal-title").textContent = "Descrie problema";
  document.getElementById("brand-view").style.display = "none";
  document.getElementById("series-view").style.display = "none";
  document.getElementById("model-view").style.display = "none";
  document.getElementById("choice-view").style.display = "none";
  document.getElementById("service-view").style.display = "none";
  document.getElementById("description-view").style.display = "block";
  document.getElementById("btn-next-0").style.display = "block";
  document.getElementById("btn-next-0").disabled = false;
  document.getElementById("booking-container").classList.remove("wide-container");
  setModalSize('');
  state.view = 'description'; setDot(3); updateBackBtn();
  setScrollable(false);
  animateIn(document.getElementById("description-view"));
}


function showServiceView() {
  const services = state.brand.data[state.model];
  if (!services) return;
  document.getElementById("modal-title").textContent = "Alege Serviciile";
  document.getElementById("brand-view").style.display = "none";
  document.getElementById("series-view").style.display = "none";
  document.getElementById("model-view").style.display = "none";
  document.getElementById("choice-view").style.display = "none";
  document.getElementById("service-view").style.display = "block";
  document.getElementById("btn-next-0").style.display = "block";
  document.getElementById("booking-container").classList.remove("wide-container");
  setModalSize(''); state.view = 'service'; setDot(2); updateBackBtn();
  const grid = document.getElementById("services-grid");
  grid.innerHTML = Object.entries(services).map(([name, price]) => `
    <div class="svc-card" data-id="${name}" onclick="toggleService(this)">
      <div class="name">${name}</div>
      <div class="price">${price} lei</div>
    </div>`).join("");
  updateCartUI();
  setScrollable(true);
  animateIn(document.getElementById("service-view"));
}

const SAMSUNG_SERIES = [
  { id: 'S', label: 'S Series', icon: '⚡' },
  { id: 'A', label: 'A Series', icon: '📱' },
  { id: 'Note', label: 'Note', icon: '✏️' },
  { id: 'Z', label: 'Z Fold / Flip', icon: '🪭' },
];

function getSamsungSeriesModels(seriesId) {
  const patterns = {
    S:    m => /^Samsung\s+S\d|^Samsung Galaxy S\d/i.test(m),
    A:    m => /^(Galaxy|Samsung Galaxy)\s+A\d/i.test(m),
    Note: m => /Note/i.test(m),
    Z:    m => /^Z\s+(Fold|Flip)/i.test(m),
  };
  const fn = patterns[seriesId];
  return fn ? Object.keys(SAMSUNG_DATA).filter(fn) : [];
}

function showSeriesView() {
  document.getElementById("modal-title").textContent = "Alege Seria";
  document.getElementById("brand-view").style.display = "none";
  document.getElementById("series-view").style.display = "block";
  document.getElementById("model-view").style.display = "none";
  document.getElementById("choice-view").style.display = "none";
  document.getElementById("service-view").style.display = "none";
  document.getElementById("btn-next-0").style.display = "none";
  document.getElementById("booking-container").classList.remove("wide-container");
  setModalSize(''); state.view = 'series'; setDot(1); updateBackBtn();
  setScrollable(false);
  const container = document.getElementById("series-view");
  container.innerHTML = `<div class="brand-grid">` + SAMSUNG_SERIES.map(s => {
    const count = getSamsungSeriesModels(s.id).length;
    return `<div class="brand-card" data-series="${s.id}" onclick="selectSeries('${s.id}')">
      <div style="font-size:1.8rem">${s.icon}</div>
      <div class="brand-name">${s.label}</div>
      <div class="brand-count">${count} modele</div>
    </div>`;
  }).join("") + `</div>`;
  animateIn(container);
}

function selectSeries(seriesId) {
  state.series = seriesId;
  showModelGrid(getSamsungSeriesModels(seriesId));
}

function showModelGrid(models) {
  const seriesObj = state.series ? SAMSUNG_SERIES.find(s => s.id === state.series) : null;
  document.getElementById("modal-title").textContent = seriesObj ? `Samsung ${seriesObj.label}` : "Alege Modelul";
  document.getElementById("brand-view").style.display = "none";
  document.getElementById("series-view").style.display = "none";
  document.getElementById("model-view").style.display = "block";
  document.getElementById("choice-view").style.display = "none";
  document.getElementById("service-view").style.display = "none";
  document.getElementById("btn-next-0").style.display = "none";
  document.getElementById("booking-container").classList.add("wide-container");
  setModalSize('modal-wide'); state.view = 'model'; setDot(1); updateBackBtn();
  const modelView = document.getElementById("model-view");
  modelView.innerHTML = `<div class="model-grid">${models.map(m => {
    const imgUrl = getPhoneImageUrl(state.brand.id, m);
    const safeModel = m.replace(/'/g,"\\'");
    return `<div class="model-card" onclick="selectModel('${safeModel}', this)">
      <img class="model-thumb" src="${imgUrl}" alt="${m}" onerror="onPhoneImgError(this)" loading="lazy">
      <span class="model-name">${m}</span>
    </div>`;
  }).join("")}</div>`;
  setScrollable(true);
  animateIn(modelView);
}

function updateBackBtn() {
  const btn = document.getElementById('back-btn');
  const show = (currentStep === 0 && state.view !== 'brand') || currentStep === 1 || currentStep === 2;
  btn.style.display = show ? 'flex' : 'none';
}

function goBack() {
  navDir = -1;
  if (currentStep === 2) { goStep(1); return; }
  if (currentStep === 1) {
    document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
    document.getElementById("step-0").classList.add("active");
    currentStep = 0;
    document.getElementById("booking-scroll").scrollTo({ top: 0, behavior: "smooth" });
    if (state.mode === 'diagnoza') { showChoiceView(); }
    else {
      document.getElementById("choice-view").style.display = "none";
      const svcView = document.getElementById("service-view");
      svcView.style.display = "block";
      animateIn(svcView);
      document.getElementById("btn-next-0").style.display = "block";
      state.view = 'service'; setDot(2); updateBackBtn();
    }
    return;
  }
  switch (state.view) {
    case 'series': showBrands(); break;
    case 'model': if (state.brand.id === 'samsung') showSeriesView(); else showBrands(); break;
    case 'choice': { const models = Object.keys(state.brand.data); if (models.length === 1) { showBrands(); break; } if (state.series) showModelGrid(getSamsungSeriesModels(state.series)); else showModelGrid(models); break; }
    case 'service': showChoiceView(); break;
    case 'description': showChoiceView(); break;
    default: showBrands();
  }
}

function toggleService(el) {
  if (el._busy) return;
  el._busy = true;
  setTimeout(() => { el._busy = false; }, 400);

  const id = el.dataset.id;
  const idx = state.cart.indexOf(id);
  const selecting = idx === -1;
  if (selecting) state.cart.push(id); else state.cart.splice(idx, 1);
  updateCartUI();

  if (selecting) {
    el.classList.remove('tapping-select', 'tapping-deselect');
    void el.offsetWidth;
    el.classList.add('tapping-select');
    el.addEventListener('animationend', () => el.classList.remove('tapping-select', 'tapping-deselect'), { once: true });
  } else {
    el.classList.remove('tapping-select', 'tapping-deselect');
  }
}

function updateCartUI() {
  document.querySelectorAll(".svc-card").forEach(card => card.classList.toggle("selected", state.cart.includes(card.dataset.id)));
  document.getElementById("btn-next-0").disabled = state.cart.length === 0;
}

function getTotal() {
  if (!state.brand || !state.model) return 0;
  const services = state.brand.data[state.model];
  return state.cart.reduce((sum, id) => { if (id === "Diagnosticare in Locatie") return sum; return sum + (services[id] || 0); }, 0);
}

function getSelectedServices() {
  if (!state.brand || !state.model) return [];
  const services = state.brand.data[state.model];
  return state.cart.map(id => ({ id, name: id, price: id === "Diagnosticare in Locatie" ? 0 : (services[id] || 0) }));
}

function initDatePicker() {
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  const maxDate = new Date();
  maxDate.setDate(maxDate.getDate() + 30);
  flatpickr("#date-picker", {
    minDate: tomorrow, maxDate, dateFormat: "Y-m-d", defaultDate: tomorrow, disableMobile: true,
    onChange(sel, dateStr) { state.date = dateStr; checkStep1Ready(); }
  });
  const y = tomorrow.getFullYear(), m = String(tomorrow.getMonth()+1).padStart(2,"0"), d = String(tomorrow.getDate()).padStart(2,"0");
  state.date = `${y}-${m}-${d}`;
}

function initTimeSlots() {
  document.querySelectorAll(".time-slot").forEach(slot => {
    slot.addEventListener("click", () => {
      document.querySelectorAll(".time-slot").forEach(s => s.classList.remove("selected"));
      slot.classList.add("selected");
      state.timeSlot = slot.dataset.slot;
      checkStep1Ready();
    });
  });
}

function checkStep1Ready() {
  document.getElementById("btn-next-1").disabled = !(state.date && state.timeSlot && state.name.trim().length >= 2 && state.phone.replace(/\s/g,"").length >= 6);
}

document.getElementById("btn-next-0").addEventListener("click", () => goStep(1));
document.getElementById("btn-next-1").addEventListener("click", () => goStep(2));

function setDot(n) {
  const dots = document.querySelectorAll(".steps .dot");
  dots.forEach((d, i) => { d.classList.remove("active","done"); if (i === n) d.classList.add("active"); else if (i < n) d.classList.add("done"); });
}

function goStep(n) {
  if (n > 0) setModalSize('');
  if (n === 2) buildSummary();
  setScrollable(false);
  const stepTitles = {1:'Programeaza Ridicarea', 2:'Sumar Comanda', 3:'Confirmare'};
  if (stepTitles[n]) document.getElementById('modal-title').textContent = stepTitles[n];
  document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
  const next = document.getElementById(`step-${n}`);
  next.classList.add("active");
  animateIn(next);
  setDot(n + 2);
  currentStep = n;
  updateBackBtn();
  if (n === 1) checkStep1Ready();
  document.getElementById("booking-scroll").scrollTo({ top: 0, behavior: "smooth" });
}

function editServices() {
  document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
  document.getElementById("step-0").classList.add("active");
  currentStep = 0;
  document.getElementById("booking-scroll").scrollTo({ top: 0, behavior: "smooth" });
  showChoiceView();
}

function buildSummary() {
  const services = getSelectedServices(), total = getTotal(), isFree = total === 0, isDiagnoza = state.mode === 'diagnoza';
  document.getElementById("summary-section-label").textContent = isDiagnoza ? "Diagnoza" : "Servicii";
  document.getElementById("summary-services").innerHTML =
    `<div class="summary-svc-item" style="font-weight:600;color:var(--accent);margin-bottom:4px"><span>${state.brand.name} · ${state.model}</span><span></span></div>` +
    (isDiagnoza ? `<div class="summary-svc-item"><span>Verificare completa</span><span style="color:#22c55e;font-weight:700">GRATIS</span></div>`
      : services.map(s => `<div class="summary-svc-item"><span>${s.name}</span><span>${s.price === 0 ? 'GRATUIT' : s.price + ' lei'}</span></div>`).join(""));
  const totalEl = document.getElementById("summary-total");
  totalEl.textContent = isFree ? "GRATUIT" : total + " lei";
  totalEl.style.color = isFree ? "#22c55e" : "var(--accent)";
  document.getElementById("summary-name").textContent = state.name;
  document.getElementById("summary-phone").textContent = state.phone;
  document.getElementById("summary-date").textContent = state.date;
  const slotHours = { "Dimineata": "9:00 – 12:00", "Dupa-amiaza": "12:00 – 17:00" };
  document.getElementById("summary-time").textContent = `${state.timeSlot} (${slotHours[state.timeSlot]})`;
  document.getElementById("pay-amount").textContent = total;
  document.getElementById("pay-methods").style.display = isFree ? "none" : "flex";
  document.querySelector(".pay-divider").style.display = isFree ? "none" : "block";
  document.getElementById("btn-pay").style.display = isFree ? "none" : "block";
  document.getElementById("btn-book-free").style.display = isFree ? "block" : "none";
}

function setPayLoading(loading) {
  const btn = document.getElementById("btn-pay");
  const methods = document.getElementById("pay-methods");
  if (loading) { btn.disabled = true; btn.textContent = "Se proceseaza..."; methods.querySelectorAll(".pay-btn").forEach(b => b.disabled = true); }
  else { btn.disabled = false; btn.innerHTML = `Plateste cu cardul — <span id="pay-amount">${getTotal()}</span> lei`; methods.querySelectorAll(".pay-btn").forEach(b => b.disabled = false); }
}

async function initiatePayment(method) {
  method = method || "card";
  setPayLoading(true);
  const services = getSelectedServices(), total = getTotal();
  try {
    const orderResp = await fetch(`${CONFIG.API_BASE}/api/create-order`, {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ amount: total, currency: CONFIG.CURRENCY, services, date: state.date, timeSlot: state.timeSlot, phone: state.phone, name: state.name, model: state.model, brand: state.brand.name, description: state.description }),
    });
    const orderData = await orderResp.json();
    state.orderId = orderData.order_id;
    if (orderData.mode === "live" && orderData.revolut_order_token) {
      startRevolutCheckout(orderData.revolut_order_token, services, total, method);
    } else {
      await new Promise(resolve => setTimeout(resolve, 1200));
      await completePayment(services, total);
    }
  } catch (err) {
    console.error("Payment error:", err);
    setPayLoading(false);
    alert("Plata a esuat. Te rugam sa incerci din nou.");
  }
}

function startRevolutCheckout(token, services, total, method) {
  if (!window.RevolutCheckout) { setTimeout(() => completePayment(services, total), 1200); return; }
  RevolutCheckout(token).then(instance => {
    const callbacks = {
      onSuccess() { completePayment(services, total); },
      onError(error) { console.error("Revolut error:", error); setPayLoading(false); },
      onCancel() { setPayLoading(false); },
    };
    if (method === "googlePay" || method === "applePay") {
      let completed = false;
      const fallbackTimer = setTimeout(() => { if (!completed) { completed = true; completePayment(services, total); } }, 2000);
      try {
        instance.paymentRequest({ target: document.getElementById("revolut-pay"), requestShipping: false,
          onSuccess() { if (!completed) { completed = true; clearTimeout(fallbackTimer); completePayment(services, total); } },
          onError() { if (!completed) { completed = true; clearTimeout(fallbackTimer); completePayment(services, total); } },
          onCancel() { if (!completed) { completed = true; clearTimeout(fallbackTimer); setPayLoading(false); } },
        });
      } catch (e) { if (!completed) { completed = true; clearTimeout(fallbackTimer); completePayment(services, total); } }
    } else { instance.payWithPopup(callbacks); }
  }).catch(err => { console.error("RevolutCheckout init error:", err); setPayLoading(false); });
}

async function bookFreeAppointment() {
  const services = getSelectedServices();
  const btn = document.getElementById("btn-book-free");
  btn.disabled = true; btn.textContent = "Se programeaza...";
  try {
    const orderResp = await fetch(`${CONFIG.API_BASE}/api/create-order`, { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ amount:0, currency:CONFIG.CURRENCY, services, date:state.date, timeSlot:state.timeSlot, phone:state.phone, name:state.name, model:state.model, brand:state.brand.name, description:state.description }) });
    const orderData = await orderResp.json();
    state.orderId = orderData.order_id;
    await fetch(`${CONFIG.API_BASE}/api/payment-complete`, { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ order_id:state.orderId, services, date:state.date, timeSlot:state.timeSlot, amount:0, phone:state.phone, name:state.name, model:state.model, brand:state.brand.name }) });
  } catch (err) { console.error("Booking error:", err); }
  btn.disabled = false; btn.textContent = "Programeaza Diagnosticarea";
  document.querySelector(".confirm-title").textContent = "Programare confirmata!";
  document.querySelector(".confirm-sub").innerHTML = "Diagnosticarea a fost programata cu succes.<br>Magazinul a fost notificat automat.";
  buildFinalSummary(); goStep(3);
}

async function completePayment(services, total) {
  document.querySelector(".confirm-title").textContent = "Plata efectuata cu succes!";
  document.querySelector(".confirm-sub").innerHTML = "Reparatia ta a fost programata.<br>Magazinul a fost notificat automat.";
  try {
    await fetch(`${CONFIG.API_BASE}/api/payment-complete`, { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ order_id:state.orderId, services, date:state.date, timeSlot:state.timeSlot, amount:total, phone:state.phone, name:state.name, model:state.model, brand:state.brand.name }) });
  } catch (err) { console.error("Notification error:", err); }
  buildFinalSummary(); goStep(3); setPayLoading(false);
}

function buildFinalSummary() {
  document.getElementById("order-id").textContent = `Comanda ${state.orderId}`;
}

function resetAll() {
  state = { brand:null, series:null, model:null, cart:[], date:null, timeSlot:null, name:"", phone:"", orderId:null, mode:null, view:'brand', description:"" };
  document.getElementById("problem-input").value = "";
  document.getElementById("description-view").style.display = "none";
  document.querySelectorAll(".time-slot").forEach(s => s.classList.remove("selected"));
  document.getElementById("name-input").value = "";
  document.getElementById("phone-input").value = "";
  document.getElementById("btn-next-0").disabled = true;
  document.getElementById("btn-next-1").disabled = true;
  const fp = document.querySelector("#date-picker")._flatpickr;
  if (fp) { const t = new Date(); t.setDate(t.getDate()+1); fp.setDate(t, true); }
  document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
  document.getElementById("step-0").classList.add("active");
  currentStep = 0; setDot(0); updateBackBtn();
  showBrands();
}
</script>
</body>
</html>