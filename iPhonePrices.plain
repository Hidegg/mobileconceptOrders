<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Mobile Concept GSM</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23151518'/><text x='50' y='68' font-size='50' font-family='Arial' font-weight='bold' fill='%238176FF' text-anchor='middle'>MC</text></svg>">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;scrollbar-width:none;-ms-overflow-style:none}
html::-webkit-scrollbar,body::-webkit-scrollbar{display:none}
:root{
  --bg:#0d0c12;
  --surface:#1c1b1b;
  --surface2:#242330;
  --border:#2d2b40;
  --text:#F4EDFF;
  --text2:#D4D4D4;
  --text3:#6a6880;
  --accent:#8176FF;
  --accent-light:rgba(129,118,255,.12);
  --accent-hover:#9a91ff;
  --accent2:#61CE70;
  --btn-bg:#534D9F;
  --btn-hover:#6B5EFF;
  --header-bg:#151518;
  --radius:12px;
  --shadow:0 2px 12px rgba(0,0,0,.5);
}

/* ── Landing ── */
body{background:#000;color:#fff;font-family:'Montserrat',sans-serif}
#landing{
  width:100%;height:100vh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:32px;
}
#landing .gsm-text{
  font-size:clamp(3rem,12vw,8rem);
  font-weight:800;
  letter-spacing:-.03em;
  color:#fff;
}

/* ── Booking overlay backdrop ── */
#booking-overlay{
  display:none;
  position:fixed;top:0;right:0;bottom:0;left:0;
  background:rgba(0,0,0,.88);
  z-index:100;
  align-items:center;
  justify-content:center;
  padding:20px;
  font-family:'Work Sans',sans-serif;
  color:var(--text);
}
#booking-overlay.open{display:flex}

/* ── Modal card ── */
#booking-modal{
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:20px;
  max-width:540px;
  width:100%;
  max-height:calc(100vh - 40px);
  max-height:calc(100dvh - 40px);
  display:flex;
  flex-direction:column;
  overflow:hidden;
  box-shadow:0 32px 80px rgba(0,0,0,.85);
}
@media(min-width:900px){
  #booking-modal{max-height:calc(100vh - 48px);max-height:calc(100dvh - 48px)}
  #booking-modal.modal-wide{max-width:820px}
  .container.wide-container{max-width:100%}
}

/* ── Modal header (steps + title + back + close) ── */
.modal-header{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px 16px 20px;
  flex-shrink:0;
  border-bottom:1px solid var(--border);
  position:relative;
}
.modal-header-center{
  display:flex;align-items:center;justify-content:center;
}
.modal-title{
  font-family:'Montserrat',sans-serif;font-size:.88rem;font-weight:700;
  color:var(--text);letter-spacing:.2px;text-align:center;
  padding:22px 16px 2px;flex-shrink:0;
}

/* ── Modal scrollable body ── */
#booking-scroll{
  overflow-y:auto;
  flex:1;
  scrollbar-width:none;-ms-overflow-style:none;
  overscroll-behavior:contain;
  -webkit-overflow-scrolling:touch;
  touch-action:pan-y;
}
#booking-scroll::-webkit-scrollbar{display:none}

/* ── Close button ── */
#close-booking{
  position:absolute;right:8px;
  background:none;border:none;
  color:var(--text2);font-size:1.1rem;
  cursor:pointer;border-radius:50%;line-height:1;
  transition:color .15s,background .15s;
  min-width:44px;min-height:44px;
  display:flex;align-items:center;justify-content:center;
}
#close-booking:hover{color:var(--text);background:var(--surface2)}
#close-booking:active{color:var(--text);background:var(--surface2)}

/* ────────────────────────────────────────────
   POPUP STYLES (from serviceCheckout)
──────────────────────────────────────────── */
.container{max-width:520px;width:100%;padding:24px 20px 28px;margin:0 auto}

.steps{
  display:flex;justify-content:center;align-items:center;gap:14px;
  pointer-events:none;
}
.steps .dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--border);position:relative;
  transition:background .35s,transform .35s,opacity .35s,box-shadow .35s;
}
.steps .dot.done{background:var(--accent);opacity:.35}
.steps .dot.active{background:var(--accent);transform:scale(1.35);box-shadow:0 0 0 4px rgba(129,118,255,.22)}

.step{display:none}
.step.active{display:block}

.step-title{font-family:'Montserrat',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:16px;color:var(--text);text-align:center;letter-spacing:.2px}

.services-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.svc-card{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);
  padding:20px 12px 16px;cursor:pointer;transition:border-color .15s,background .15s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;gap:8px;position:relative;
}
.svc-card:hover,.svc-card:active{border-color:var(--accent);background:var(--accent-light)}
.svc-card.selected{border-color:var(--accent);background:var(--accent-light)}
.svc-card .name{font-family:'Montserrat',sans-serif;font-weight:600;font-size:.8rem;line-height:1.3;color:var(--text)}
.svc-card .price{font-family:'Montserrat',sans-serif;color:var(--accent);font-weight:700;font-size:.88rem}

.brand-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.brand-card{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);
  padding:28px 16px;cursor:pointer;transition:border-color .15s,background .15s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;gap:10px;
}
.brand-card:hover,.brand-card:active{border-color:var(--accent);background:var(--accent-light)}
.brand-card.selected{border-color:var(--accent);background:var(--accent-light)}
.brand-card.placeholder{opacity:.38;cursor:default}
.brand-card.placeholder:hover{border-color:var(--border);box-shadow:var(--shadow)}
.brand-card .brand-icon{width:58px;height:58px;display:flex;align-items:center;justify-content:center;
  background:transparent;border-radius:14px;border:none;overflow:hidden;flex-shrink:0}
.brand-logo{width:40px;height:40px;object-fit:contain;filter:brightness(0) invert(1);opacity:.85}
.brand-card .brand-name{font-family:'Montserrat',sans-serif;font-weight:700;font-size:1rem}
.brand-card .brand-count{color:var(--text2);font-size:.72rem;margin-top:1px}

.model-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.model-card{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);
  padding:16px 12px;cursor:pointer;transition:border-color .15s,background .15s;
  display:flex;flex-direction:column;align-items:center;text-align:center;gap:10px;
}
.model-card:hover,.model-card:active{border-color:var(--accent);background:var(--accent-light)}
.model-card.selected{border-color:var(--accent);background:var(--accent-light)}
.model-card .model-name{font-family:'Montserrat',sans-serif;font-weight:600;font-size:.78rem;line-height:1.35;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.model-thumb{width:80px;height:80px;object-fit:contain;border-radius:8px;background:rgba(255,255,255,.05);flex-shrink:0;padding:6px}

#back-btn{
  position:absolute;left:8px;
  background:none;border:none;color:var(--text2);font-size:1.25rem;
  cursor:pointer;border-radius:50%;line-height:1;
  transition:color .15s,background .15s;
  display:none;align-items:center;justify-content:center;
  min-width:44px;min-height:44px;
}
#back-btn:hover{color:var(--accent);background:var(--surface2)}
#back-btn:active{color:var(--accent);background:var(--surface2)}



.date-section{margin-bottom:22px}
.date-section label{display:block;font-weight:600;margin-bottom:8px;font-size:.88rem;color:var(--text2)}
.flatpickr-input{
  width:100%;padding:13px 14px;border-radius:var(--radius);border:1px solid var(--border);
  background:var(--surface);color:var(--text);font-family:inherit;font-size:.92rem;
  box-shadow:var(--shadow);outline:none;transition:border .15s;
}
.flatpickr-input:focus{border-color:var(--accent)}
.desc-hint{font-size:.75rem;color:var(--text3);margin-top:8px;line-height:1.5;text-align:center}
.time-slots{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:14px}
.time-slot{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);
  padding:16px 8px;text-align:center;cursor:pointer;transition:all .15s;box-shadow:var(--shadow);
}
.time-slot:hover{border-color:var(--text3)}
.time-slot:active{border-color:var(--accent);background:var(--accent-light)}
.time-slot.selected{border-color:var(--accent);background:var(--accent-light)}
.time-slot .label{font-weight:600;font-size:.85rem}
.time-slot .hours{color:var(--text2);font-size:.72rem;margin-top:3px}

.summary-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:14px;
}
.summary-card h3{font-family:'Montserrat',sans-serif;margin-bottom:10px;font-size:.85rem;display:flex;align-items:center;gap:6px}
.summary-line{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:.84rem}
.summary-line:last-child{border:none}
.summary-line .lbl{color:var(--text2)}
.summary-line .val{font-weight:600}
.summary-services{margin-bottom:12px}
.summary-svc-item{display:flex;justify-content:space-between;padding:6px 0;font-size:.86rem}
.summary-total{border-top:2px solid var(--accent);padding-top:12px;margin-top:8px;display:flex;justify-content:space-between;font-weight:700;font-size:1.05rem}
.summary-total .val{color:var(--accent)}
.edit-link{color:var(--accent);font-size:.78rem;cursor:pointer;text-decoration:none;font-weight:500}
.edit-link:hover{text-decoration:underline}

.receipt-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;
}
.receipt-section{padding:8px 14px}
.receipt-section-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.receipt-lbl{
  font-family:'Montserrat',sans-serif;font-size:.65rem;font-weight:700;
  text-transform:uppercase;letter-spacing:1px;color:var(--text3);
}
.receipt-divider{height:1px;background:var(--border)}
.receipt-row{
  display:flex;justify-content:space-between;align-items:baseline;
  padding:4px 0;font-size:.83rem;
}
.receipt-row .lbl{color:var(--text2)}
.receipt-row .val{font-weight:600;text-align:right;max-width:58%}
.receipt-total{
  padding:10px 14px;background:var(--surface2);
  border-top:2px solid var(--accent);
  display:flex;justify-content:space-between;align-items:center;
  font-family:'Montserrat',sans-serif;font-weight:700;font-size:.95rem;
}
.receipt-card .summary-svc-item{padding:4px 0;font-size:.84rem}

#step-2 .btn, #step-3 .btn{padding:14px;margin-top:14px}
#btn-next-0{margin-top:24px}

.btn{
  width:100%;padding:12px;border:none;border-radius:9999px;
  font-family:'Montserrat',sans-serif;font-size:.9rem;font-weight:600;
  cursor:pointer;transition:all .15s;margin-top:10px;letter-spacing:.3px;
}
.btn-primary{background:var(--btn-bg);color:#fff}
.btn-primary:hover{background:var(--btn-hover)}
.btn-primary:disabled{background:#2a2938;color:#4a4860;cursor:not-allowed;transform:none}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:var(--accent-hover)}
.btn-accent:disabled{background:#2a2938;color:#4a4860;cursor:not-allowed}
.btn-secondary{background:var(--surface);color:var(--text);border:1px solid var(--border)}
.btn-secondary:hover{background:var(--surface2)}
.btn-back{background:none;color:var(--text2);border:none;font-size:.82rem;margin-top:10px;cursor:pointer;padding:8px 0}
.btn-back:hover{color:var(--accent)}

#revolut-pay{margin-top:8px;min-height:0}
.payment-placeholder{
  background:var(--surface2);border:2px dashed var(--border);border-radius:var(--radius);
  padding:28px;text-align:center;color:var(--text2);font-size:.82rem;margin-top:16px;
}
.pay-methods{display:flex;gap:8px;margin-top:8px}
.pay-methods .pay-btn{
  flex:1;padding:10px;border:1px solid var(--border);border-radius:9999px;
  background:var(--surface);cursor:pointer;font-family:inherit;font-size:.85rem;
  font-weight:600;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;
}
.pay-methods .pay-btn:hover{background:var(--surface2);border-color:var(--text3)}
.pay-methods .pay-btn.gpay{background:#1a1924;color:#F4EDFF;border-color:#3d3b55}
.pay-methods .pay-btn.gpay:hover{background:#242330;border-color:var(--accent)}
.pay-methods .pay-btn.applepay{background:#1a1924;color:#F4EDFF;border-color:#3d3b55}
.pay-methods .pay-btn.applepay:hover{background:#242330;border-color:var(--accent)}
.pay-divider{text-align:center;color:var(--text3);font-size:.78rem;margin:8px 0;position:relative}
.pay-divider::before,.pay-divider::after{content:"";position:absolute;top:50%;width:calc(50% - 20px);height:1px;background:var(--border)}
.pay-divider::before{left:0}
.pay-divider::after{right:0}

.confirm-check{
  width:48px;height:48px;border-radius:50%;background:var(--accent);
  display:flex;align-items:center;justify-content:center;margin:0 auto 12px;
}
.confirm-check svg{width:24px;height:24px;stroke:#fff;stroke-width:3;fill:none}
.confirm-title{font-family:'Montserrat',sans-serif;text-align:center;font-size:1.05rem;font-weight:700;margin-bottom:4px}
.confirm-sub{text-align:center;color:var(--text2);font-size:.82rem;margin-bottom:12px;line-height:1.5}
.order-id{text-align:center;color:var(--text3);font-size:.75rem;margin-bottom:12px;font-family:'Courier New',monospace;letter-spacing:.5px}

@media(min-width:600px){
  .model-grid{grid-template-columns:repeat(4,1fr)}
}
@media(max-width:480px){
  .choice-card{padding:18px 14px 16px;gap:12px}
  .choice-icon-wrap{width:44px;height:44px;font-size:1.3rem}
}
@media(max-width:380px){
  .services-grid{grid-template-columns:1fr}
  .time-slots{grid-template-columns:1fr 1fr !important}
  .pay-methods{flex-direction:column}
  .pay-methods .pay-btn{width:100%}
  .container{padding:20px 12px 32px}
  .svc-card{padding:14px 12px}
  .choice-card{padding:14px 12px 14px;gap:10px}
  .choice-icon-wrap{width:40px;height:40px;font-size:1.15rem}
  .choice-title{font-size:.95rem}
  .choice-sub{font-size:.74rem}
}

.choice-grid{display:flex;flex-direction:column;gap:16px;margin-top:14px}
.choice-card{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);
  padding:26px 22px 24px;cursor:pointer;
  transition:border-color .18s,background .18s;
  box-shadow:var(--shadow);
  display:flex;flex-direction:row;align-items:flex-start;gap:18px;
}
.choice-card:hover{}
.choice-card:active{transition-duration:.08s}
.choice-card-servicii:hover,.choice-card-servicii:active,.choice-card-servicii.selected{
  border-color:var(--accent);background:var(--accent-light);
}
.choice-card-diagnoza:hover,.choice-card-diagnoza:active,.choice-card-diagnoza.selected{
  border-color:#22c55e;background:rgba(34,197,94,.07);
}
.choice-icon-wrap{
  width:52px;height:52px;border-radius:14px;
  background:rgba(129,118,255,.12);
  display:flex;align-items:center;justify-content:center;
  font-size:1.55rem;flex-shrink:0;
}
.choice-icon-wrap.green{background:rgba(34,197,94,.1)}
.choice-body{flex:1}
.choice-title{font-family:'Montserrat',sans-serif;font-weight:700;font-size:1.05rem;line-height:1.3}
.choice-sub{font-size:.79rem;color:var(--text2);margin-top:5px;line-height:1.45}
.choice-range{font-family:'Montserrat',sans-serif;font-weight:700;font-size:.85rem;color:var(--accent);margin-top:6px}
.choice-price-zero{font-family:'Montserrat',sans-serif;font-weight:800;font-size:.85rem;color:#22c55e;margin-top:6px}
.choice-tags{display:flex;gap:5px;flex-wrap:nowrap;margin-top:12px;overflow:hidden}
.choice-tag{font-size:.7rem;border-radius:999px;padding:3px 8px;font-family:'Montserrat',sans-serif;white-space:nowrap}
.choice-card-servicii .choice-tag{color:var(--accent);background:var(--accent-light)}
.choice-card-diagnoza .choice-tag{color:#22c55e;background:rgba(34,197,94,.1)}
.choice-right{display:flex;flex-direction:column;align-items:flex-end;justify-content:flex-start;gap:8px;flex-shrink:0;padding-top:2px}
.choice-arrow{color:var(--text3);font-size:1.1rem;line-height:1}
.choice-gratis{
  font-family:'Montserrat',sans-serif;font-weight:800;font-size:.78rem;
  color:#22c55e;letter-spacing:.5px;
  background:rgba(34,197,94,.12);padding:3px 10px;border-radius:999px;
}

/* ── Tap animations ── */
@keyframes brand-tap {
  0%   { transform:scale(1); }
  28%  { transform:scale(.95);  border-color:var(--accent); box-shadow:0 0 0 5px rgba(129,118,255,.22); background:var(--accent-light); }
  62%  { transform:scale(1.02); border-color:var(--accent); box-shadow:0 0 0 3px rgba(129,118,255,.14); background:var(--accent-light); }
  100% { transform:scale(1);    border-color:var(--border); box-shadow:none; background:var(--surface); }
}
@keyframes diagnoza-tap {
  0%   { transform:scale(1); }
  28%  { transform:scale(.95);  border-color:#22c55e; box-shadow:0 0 0 5px rgba(34,197,94,.22); background:rgba(34,197,94,.07); }
  62%  { transform:scale(1.02); border-color:#22c55e; box-shadow:0 0 0 3px rgba(34,197,94,.14); background:rgba(34,197,94,.07); }
  100% { transform:scale(1);    border-color:var(--border); box-shadow:none; background:var(--surface); }
}
@keyframes svc-select {
  0%   { transform:scale(1);    border-color:var(--border); background:var(--surface); }
  30%  { transform:scale(.93);  border-color:var(--accent); background:var(--accent-light); }
  65%  { transform:scale(1.02); border-color:var(--accent); background:var(--accent-light); }
  100% { transform:scale(1);    border-color:var(--accent); background:var(--accent-light); }
}
@keyframes svc-deselect {
  0%   { transform:scale(1);    border-color:var(--accent); background:var(--accent-light); }
  30%  { transform:scale(.93);  border-color:var(--border); background:var(--surface); }
  65%  { transform:scale(1.02); border-color:var(--border); background:var(--surface); }
  100% { transform:scale(1);    border-color:var(--border); background:var(--surface); }
}
.brand-card.tapping,.model-card.tapping,.choice-card-servicii.tapping {
  animation:brand-tap 340ms cubic-bezier(.25,.8,.25,1) forwards;
  pointer-events:none;transition:none;
}
.choice-card-diagnoza.tapping {
  animation:diagnoza-tap 340ms cubic-bezier(.25,.8,.25,1) forwards;
  pointer-events:none;transition:none;
}
.svc-card.tapping-select {
  animation:svc-select 260ms cubic-bezier(.25,.8,.25,1) forwards;
  transition:none;
}
.svc-card.tapping-deselect {
  animation:svc-deselect 260ms cubic-bezier(.25,.8,.25,1) forwards;
  transition:none;
}

/* ── Mobile / Touch fixes ── */
#booking-scroll.scroll-locked{overflow-y:hidden !important}

/* Touch tap highlight — JS-driven via touchstart/touchend, reliable on iOS */
.brand-card.touch-active:not(.placeholder){border-color:var(--accent);background:var(--accent-light)}
.model-card.touch-active{border-color:var(--accent);background:var(--accent-light)}

.time-slot.touch-active{border-color:var(--accent);background:var(--accent-light)}
.choice-card-servicii.touch-active{border-color:var(--accent);background:var(--accent-light);box-shadow:0 6px 20px rgba(129,118,255,.18)}
.choice-card-diagnoza.touch-active{border-color:#22c55e;background:rgba(34,197,94,.07);box-shadow:0 6px 20px rgba(34,197,94,.15)}

/* On touch devices: disable hover (fires on scroll), keep :active for tap feedback */
@media(hover:none){

  .brand-card:hover{border-color:var(--border);background:var(--surface)}
  .brand-card.placeholder:hover{border-color:var(--border)}
  .model-card:hover{border-color:var(--border);background:var(--surface)}
  .choice-card:hover{box-shadow:var(--shadow)}
  .choice-card-servicii:hover{border-color:var(--border);background:var(--surface);box-shadow:var(--shadow)}
  .choice-card-diagnoza:hover{border-color:var(--border);background:var(--surface);box-shadow:var(--shadow)}
  .time-slot:hover{border-color:var(--border);transform:none}
  .btn-primary:hover{background:var(--btn-bg)}
  .btn-accent:hover{background:var(--accent)}
  .btn-secondary:hover{background:var(--surface)}
  .btn-back:hover{color:var(--text2)}
  .pay-methods .pay-btn:hover{background:var(--surface);border-color:var(--border)}
  .pay-methods .pay-btn.gpay:hover{background:#1a1924;border-color:#3d3b55}
  .pay-methods .pay-btn.applepay:hover{background:#1a1924;border-color:#3d3b55}
  #close-booking:hover{color:var(--text2);background:none}
  #back-btn:hover{color:var(--text2);background:none}
  .edit-link:hover{text-decoration:none}
}

/* Safe area padding for notch / home indicator (iPhone X+, Android) */
@supports(padding:max(0px)){
  #booking-overlay{
    padding:max(20px,env(safe-area-inset-top)) max(20px,env(safe-area-inset-right)) max(20px,env(safe-area-inset-bottom)) max(20px,env(safe-area-inset-left))
  }
}

/* ── Flatpickr theme — match app palette ── */
.flatpickr-calendar{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:0 8px 32px rgba(0,0,0,.7);
  font-family:'Work Sans',sans-serif;
  color:var(--text);
}
.flatpickr-calendar.arrowTop:before{border-bottom-color:var(--border)}
.flatpickr-calendar.arrowTop:after{border-bottom-color:var(--surface)}
.flatpickr-calendar.arrowBottom:before{border-top-color:var(--border)}
.flatpickr-calendar.arrowBottom:after{border-top-color:var(--surface)}
.flatpickr-months{background:var(--surface);border-radius:var(--radius) var(--radius) 0 0}
.flatpickr-months .flatpickr-month{background:var(--surface);color:var(--text);fill:var(--text);height:44px}
.flatpickr-months .flatpickr-prev-month,.flatpickr-months .flatpickr-next-month{fill:var(--text2);top:10px}
.flatpickr-months .flatpickr-prev-month:hover svg,.flatpickr-months .flatpickr-next-month:hover svg{fill:var(--accent)}
.flatpickr-current-month{color:var(--text)}
.flatpickr-current-month .flatpickr-monthDropdown-months{background:var(--surface);color:var(--text);border:none;font-weight:600}
.flatpickr-current-month input.cur-year{color:var(--text);font-weight:600}
.flatpickr-weekdays{background:var(--surface2)}
span.flatpickr-weekday{background:var(--surface2);color:var(--text3);font-size:.72rem;font-weight:700;letter-spacing:.5px}
.flatpickr-days{border-left:1px solid var(--border);border-right:1px solid var(--border)}
.dayContainer{padding:4px}
.flatpickr-day{
  color:var(--text);
  border-radius:8px;
  border:1px solid transparent;
}
.flatpickr-day:hover,.flatpickr-day:focus{
  background:var(--accent-light);
  border-color:transparent;
  color:var(--text);
}
.flatpickr-day.today{
  border-color:var(--accent);
  color:var(--text);
  font-weight:600;
}
.flatpickr-day.today:hover{
  background:var(--accent-light);
  border-color:var(--accent);
  color:var(--text);
}
.flatpickr-day.selected,.flatpickr-day.selected:hover,.flatpickr-day.selected:focus{
  background:var(--accent);
  border-color:var(--accent);
  color:#fff;
  font-weight:700;
}
.flatpickr-day.flatpickr-disabled,.flatpickr-day.flatpickr-disabled:hover{
  color:var(--text3);
  opacity:.35;
}
.flatpickr-day.prevMonthDay,.flatpickr-day.nextMonthDay{
  color:var(--text3);
  opacity:.4;
}
.flatpickr-innerContainer{border-bottom:1px solid var(--border)}
.flatpickr-rContainer{width:100%}
.numInputWrapper:hover{background:var(--surface2)}
</style>
</head>
<body>

<!-- ── LANDING ── -->
<div id="landing">
  <span class="gsm-text">GSM</span>
</div>

<!-- ── BOOKING OVERLAY ── -->
<div id="booking-overlay">
  <div id="booking-modal">

  <div class="modal-header">
    <button id="back-btn" onclick="goBack()">&#8592;</button>
    <div class="modal-header-center">
      <div class="steps">
        <div class="dot active" data-step="0"></div>
        <div class="dot" data-step="1"></div>
        <div class="dot" data-step="2"></div>
        <div class="dot" data-step="3"></div>
        <div class="dot" data-step="4"></div>
        <div class="dot" data-step="5"></div>
      </div>
    </div>
    <button id="close-booking" onclick="closeBooking()" title="Inchide">&#x2715;</button>
  </div>
  <div id="modal-title" class="modal-title">Alege Marca Telefonului</div>

  <div id="booking-scroll">
  <div class="container" id="booking-container">

    <div class="step active" id="step-0">
      <div id="brand-view"></div>
      <div id="series-view" style="display:none"></div>
      <div id="model-view" style="display:none"></div>
      <div id="choice-view" style="display:none"></div>
      <div id="service-view" style="display:none">
        <div class="services-grid" id="services-grid"></div>
      </div>
      <div id="description-view" style="display:none">
        <div class="date-section">
          <textarea id="problem-input" class="flatpickr-input" rows="5"
            placeholder="Ex: Ecranul are o linie alba, telefonul nu porneste, nu se incarca..."
            oninput="state.description=this.value"
            style="resize:none;line-height:1.6;font-family:inherit"></textarea>
        </div>
      </div>
      <button class="btn btn-primary" id="btn-next-0" disabled style="display:none">Inainte</button>
    </div>

    <div class="step" id="step-1">
      <div class="date-section">
        <label>Alege o data</label>
        <input type="text" id="date-picker" class="flatpickr-input" placeholder="Selecteaza data...">
      </div>
      <div class="date-section">
        <label>Nume si prenume</label>
        <input type="text" id="name-input" class="flatpickr-input" placeholder="Numele complet" oninput="state.name=this.value;checkStep1Ready()">
      </div>
      <div class="date-section">
        <label>Numar de telefon</label>
        <input type="tel" id="phone-input" class="flatpickr-input" placeholder="07xx xxx xxx" oninput="state.phone=this.value;checkStep1Ready()">
      </div>
      <div class="date-section">
        <label>Alege intervalul orar</label>
        <div class="time-slots" id="time-slots" style="grid-template-columns:1fr 1fr">
          <div class="time-slot" data-slot="Dimineata">
            <div class="label">Dimineata</div>
            <div class="hours">9:00 – 12:00</div>
          </div>
          <div class="time-slot" data-slot="Dupa-amiaza">
            <div class="label">Dupa-amiaza</div>
            <div class="hours">12:00 – 17:00</div>
          </div>
        </div>
      </div>
      <button class="btn btn-primary" id="btn-next-1" disabled>Inainte</button>
    </div>

    <div class="step" id="step-2">
      <div class="receipt-card">
        <div class="receipt-section">
          <div class="receipt-section-hdr">
            <span class="receipt-lbl" id="summary-section-label">Servicii</span>
            <span class="edit-link" onclick="editServices()">modifica</span>
          </div>
          <div id="summary-services"></div>
        </div>
        <div class="receipt-divider"></div>
        <div class="receipt-section">
          <div class="receipt-section-hdr">
            <span class="receipt-lbl">Ridicare</span>
            <span class="edit-link" onclick="goStep(1)">modifica</span>
          </div>
          <div class="receipt-row"><span class="lbl">Nume</span><span class="val" id="summary-name">—</span></div>
          <div class="receipt-row"><span class="lbl">Telefon</span><span class="val" id="summary-phone">—</span></div>
          <div class="receipt-row"><span class="lbl">Data</span><span class="val" id="summary-date">—</span></div>
          <div class="receipt-row"><span class="lbl">Interval</span><span class="val" id="summary-time">—</span></div>
        </div>
        <div class="receipt-divider"></div>
        <div class="receipt-total">
          <span>Total</span>
          <span id="summary-total">0 lei</span>
        </div>
      </div>
      <div id="revolut-pay"></div>
      <div class="pay-methods" id="pay-methods">
        <button class="pay-btn gpay" onclick="initiatePayment('googlePay')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12.24 10.28V14.4h5.6c-.24 1.56-1.8 4.56-5.6 4.56-3.36 0-6.12-2.8-6.12-6.24s2.76-6.24 6.12-6.24c1.92 0 3.2.84 3.96 1.56l2.7-2.64C17.04 3.64 14.88 2.76 12.24 2.76 6.48 2.76 1.8 7.44 1.8 13.2s4.68 10.44 10.44 10.44c6.04 0 10.04-4.24 10.04-10.2 0-.72-.08-1.28-.16-1.8h-9.88z" fill="#fff"/></svg>
          Google Pay
        </button>
        <button class="pay-btn applepay" onclick="initiatePayment('applePay')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C3.79 16.17 4.36 9.43 8.89 9.2c1.25.07 2.12.7 2.86.73.97-.2 1.9-.82 2.93-.74 1.24.1 2.17.59 2.79 1.49-2.49 1.54-1.9 4.92.36 5.87-.45 1.2-.99 2.37-1.78 3.73zM12.03 9.15c-.12-2.35 1.84-4.37 4.04-4.55.28 2.6-2.33 4.63-4.04 4.55z"/></svg>
          Apple Pay
        </button>
      </div>
      <div class="pay-divider">sau</div>
      <button class="btn btn-accent" id="btn-pay" onclick="initiatePayment('card')">Plateste cu cardul — <span id="pay-amount">0</span> lei</button>
      <button class="btn btn-accent" id="btn-book-free" style="display:none" onclick="bookFreeAppointment()">Programeaza Diagnosticarea</button>
    </div>

    <div class="step" id="step-3">
      <div class="confirm-check">
        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="confirm-title">Plata efectuata cu succes!</div>
      <div class="confirm-sub">Reparatia ta a fost programata.<br>Magazinul a fost notificat automat.</div>
      <div class="order-id" id="order-id"></div>
      <button class="btn btn-primary" style="margin-top:16px" onclick="resetAll()">Programeaza Alt Serviciu</button>
    </div>

  </div>
  </div><!-- /booking-scroll -->
  </div><!-- /booking-modal -->
</div><!-- /booking-overlay -->

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://sandbox-merchant.revolut.com/embed.js" defer></script>
<script>
const CONFIG = {
  API_BASE: "",
  CURRENCY: "RON",
  SHOP_NAME: "Mobile Concept GSM"
};

/* ── Open / Close overlay ── */
let _bodyScrollY = 0;
function openBooking() {
  _bodyScrollY = window.scrollY || window.pageYOffset;
  document.body.style.overflow = "hidden";
  document.body.style.position = "fixed";
  document.body.style.top = `-${_bodyScrollY}px`;
  document.body.style.width = "100%";
  document.body.style.webkitOverflowScrolling = "auto";
  document.getElementById("booking-overlay").classList.add("open");
  initDatePicker(); initTimeSlots();
}
function closeBooking() {
  document.getElementById("booking-overlay").classList.remove("open");
  document.body.style.overflow = "";
  document.body.style.position = "";
  document.body.style.top = "";
  document.body.style.width = "";
  document.body.style.webkitOverflowScrolling = "";
  window.scrollTo(0, _bodyScrollY);
}

